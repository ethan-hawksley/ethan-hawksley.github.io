---
import { Image } from 'astro:assets';
import A from './A.astro';
interface Props {
  name: string;
  description: string;
  image: ImageMetadata;
  liveUrl?: string;
  sourceUrl: string;
}
const { name, image, description, sourceUrl, liveUrl } = Astro.props;
---

<article>
  <Image src={image} alt={`Screenshot of ${name}.`} />
  <div class="card-body">
    <h3>{name}</h3>
    <p>{description}</p>
    <footer>
      <A href={sourceUrl} aria-label={`View ${name} source code`}>Source Code</A
      >
      {
        liveUrl && (
          <A href={liveUrl} aria-label={`View ${name} live demo`}>
            Live Demo
          </A>
        )
      }
    </footer>
  </div>
</article>

<style>
  article {
    background-color: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  article :global(img) {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }

  h3 {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-snug);
  }

  p {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    flex-grow: 1;
  }

  footer {
    display: flex;
    gap: 1rem;
  }

  footer :global(a:active) {
    transform: scale(0.96);
  }
</style>
