---
import Email from '../assets/email.svg';
import Github from '../assets/github.svg';
import Linkedin from '../assets/linkedin.svg';
import A from './A.astro';
---

<address>
  <A href="mailto:..." rel="me" pressable>
    <Email aria-hidden="true" />
    ethan<span class="punct">.dev</span>@hawksley<span class="punct">.co</span
    >.dev</A
  >
  <A href="https://github.com/ethan-hawksley" rel="me" pressable>
    <Github aria-hidden="true" />
    GitHub</A
  >
  <A href="https://www.linkedin.com/in/ethan-hawksley/" rel="me" pressable>
    <Linkedin aria-hidden="true" />
    LinkedIn</A
  >
</address>

<style>
  address {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    address {
      flex-direction: row;
      gap: 1rem;
    }
  }

  address > :global(a) {
    padding: 0.75rem 0.5rem 0.75rem 2.25rem;
    position: relative;
    display: inline-flex;
    align-items: center;
    align-content: center;
    gap: 0.5rem;
  }

  address :global(a > svg:first-child) {
    position: absolute;
    width: 24px;
    height: 24px;
    left: 0.3rem;
    top: 1.5rem;
    transform: translateY(calc(-50% + 0.125em + 1px)) !important;
  }

  .punct {
    display: none;
  }
</style>
