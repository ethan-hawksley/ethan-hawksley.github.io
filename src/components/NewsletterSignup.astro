---
const FORM_ID = '9595926';
const action = `https://app.kit.com/forms/${FORM_ID}/subscriptions`;
---

<section class="newsletter-section" aria-label="Newsletter Subscription">
  <h3 class="newsletter-heading">Get new posts in your inbox</h3>

  <form class="newsletter-form" action={action} method="post" data-kit-form>
    <div class="input-group">
      <label for="newsletter-signup-email" class="sr-only">Email address</label>
      <input
        id="newsletter-signup-email"
        type="email"
        name="email_address"
        placeholder="your@email.com"
        required
        autocomplete="email"
      />
      <button type="submit">Subscribe</button>
    </div>
  </form>

  <footer class="newsletter-meta">
    <div class="newsletter-feedback" aria-live="polite">
      <span class="newsletter-success" tabindex="-1" hidden>
        Thanks, check your inbox to confirm.
      </span>
      <span class="newsletter-error" tabindex="-1" hidden>
        Something went wrong. Please try again.
      </span>
    </div>
  </footer>
</section>

<style>
  .newsletter-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    inline-size: 100%;
    max-inline-size: 65ch;
  }

  .newsletter-heading {
    font-size: var(--font-size-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .newsletter-form {
    inline-size: 100%;
  }

  .input-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-end;
    inline-size: 100%;
  }

  .input-group input {
    flex: 1;
    min-inline-size: 200px;
    padding-block: 0.25rem;
    padding-inline: 0.15rem;
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    color: var(--color-text);
    background: transparent;
    border: none;
    border-block-end: 2px solid var(--color-border);
    border-radius: 0;
    transition: border-color 250ms ease-out;
  }

  .input-group input:focus {
    outline: none;
    border-block-end-color: var(--color-accent);
  }

  .input-group button {
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-decoration: var(--color-accent) underline 2px;
    text-underline-offset: 0.25em;
    cursor: pointer;
    background: none;
    border: none;
    transition:
      color 250ms ease-out,
      transform 100ms ease-out;
  }

  .input-group button:hover {
    color: var(--color-accent);
  }

  .input-group button:active {
    transform: scale(0.96);
  }

  .newsletter-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .newsletter-success {
    color: var(--color-text-muted);
  }

  .newsletter-error {
    color: var(--color-accent);
  }

  .newsletter-success:focus,
  .newsletter-error:focus {
    outline: none;
  }

  .input-group button[aria-disabled='true'] {
    color: var(--color-text-muted);
    text-decoration-color: var(--color-border);
    cursor: not-allowed;
  }

  @media print {
    .newsletter-section {
      display: none !important;
    }
  }
</style>

<script>
  function initNewsletter() {
    const forms = document.querySelectorAll<HTMLFormElement>(
      '[data-kit-form]:not([data-initialized])',
    );

    forms.forEach((form) => {
      form.setAttribute('data-initialized', 'true');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const container = form.closest('.newsletter-section')!;
        const success = container.querySelector<HTMLElement>(
          '.newsletter-success',
        )!;
        const error =
          container.querySelector<HTMLElement>('.newsletter-error')!;
        const button = form.querySelector('button')!;

        if (button.getAttribute('aria-disabled') === 'true') return;

        button.setAttribute('aria-disabled', 'true');
        const originalText = button.textContent;
        button.textContent = 'Subscribing…';
        error.hidden = true;

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });

          if (!res.ok) throw new Error();

          form.hidden = true;
          success.hidden = false;

          success.focus();
        } catch {
          error.hidden = false;
          button.removeAttribute('aria-disabled');
          button.textContent = originalText;

          error.focus();
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initNewsletter);
</script>
